// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  SELLER
}

enum Brand {
  BGP
  AIMO
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum TaskType {
  CALL
  EMAIL
  MEETING
  VISIT
  OTHER
}

enum TaskStatus {
  PENDING
  COMPLETED
  OVERDUE
}

enum ActivityType {
  NOTE
  EMAIL
  CALL
  MEETING
  STAGE_CHANGE
  STATUS_CHANGE
  TASK_CREATED
  TASK_COMPLETED
  TASK_RESCHEDULED
  TASK_CANCELLED
  TASK_NO_SHOW
  TASK_REASSIGNED
  DEAL_CREATED
  WEBHOOK_RECEIVED
  EMAIL_SENT
  EMAIL_OPENED
  TAG_ADDED
  TAG_REMOVED
  AUTOMATION_ENROLLED
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  MULTISELECT
}

enum CustomFieldEntity {
  CONTACT
  ORGANIZATION
  DEAL
}

enum WebhookType {
  INCOMING
  OUTGOING
}

enum EngagementLevel {
  ENGAGED
  INTERMEDIATE
  DISENGAGED
}

enum SegmentFilterOperator {
  EQUALS
  CONTAINS
  GREATER_THAN
  LESS_THAN
  IN
  NOT_IN
  BETWEEN
}

enum MeetingSource {
  CALENDLY_EMAIL
  CALENDLY_LP
  SDR_IA
  HUMANO
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum EmailStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

enum EmailSendStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  SPAM
  UNSUBSCRIBED
}

enum AutomationStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum AutomationTriggerType {
  TAG_ADDED
  TAG_REMOVED
  STAGE_CHANGED
  CONTACT_CREATED
  FIELD_UPDATED
  DATE_BASED
}

enum AutomationActionType {
  ADD_TAG
  REMOVE_TAG
  SEND_EMAIL
  SEND_WHATSAPP
  SEND_WHATSAPP_AI
  WAIT
  UPDATE_FIELD
  MOVE_PIPELINE_STAGE
  CONDITION
  MARK_LOST
  WAIT_FOR_RESPONSE
  SEND_WA_TEMPLATE
}

enum AutomationEnrollmentStatus {
  ACTIVE
  COMPLETED
  PAUSED
  FAILED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Team {
  id          String  @id @default(cuid())
  name        String
  description String?

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(SELLER)
  avatarUrl String?
  phone     String?
  isActive  Boolean  @default(true)

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id])

  deals      Deal[]
  tasks      Task[]
  activities Activity[]

  assignedConversations WhatsAppConversation[] @relation("WhatsAppConversationAssignee")
  sentWhatsAppMessages  WhatsAppMessage[]      @relation("WhatsAppMessageSender")
  cloudWaMessages       CloudWaMessageLog[]    @relation("CloudWaMessageSender")

  // ── Wa (Cloud API v2) ──
  waConversationsAssigned WaConversation[] @relation("WaConversationAssignee")
  waMessagesSent          WaMessage[]      @relation("WaMessageSender")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([teamId])
}

model Organization {
  id        String  @id @default(cuid())
  name      String
  cnpj      String? @unique
  segment   String?
  website   String?
  phone     String?
  address   String?
  instagram String?
  email     String?
  notes     String?

  contacts Contact[]
  deals    Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cnpj])
  @@index([name])
}

model Contact {
  id        String    @id @default(cuid())
  name      String
  email     String?
  phone     String?
  position  String?
  birthday  DateTime?
  instagram String?
  notes     String?
  sector    String?
  brand     Brand     @default(BGP)

  phoneInvalid   Boolean   @default(false)
  phoneInvalidAt DateTime?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  deals                 Deal[]
  tasks                 Task[]
  activities            Activity[]
  customFieldValues     CustomFieldValue[]
  leadTrackings         LeadTracking[]
  dealContacts          DealContact[]
  tags                  ContactTag[]
  leadScore             LeadScore?
  emailSends            EmailSend[]
  automationEnrollments AutomationEnrollment[]
  whatsappConversations WhatsAppConversation[]
  waConversations       WaConversation[]
  calendlyEvents        CalendlyEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([organizationId])
  @@index([name])
  @@index([brand])
}

model Pipeline {
  id        String  @id @default(cuid())
  name      String
  isDefault Boolean @default(false)
  brand     Brand   @default(BGP)

  stages PipelineStage[]
  deals  Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PipelineStage {
  id    String  @id @default(cuid())
  name  String
  order Int
  color String?

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  deals             Deal[]
  whatsappCampaigns WhatsAppCampaign[]
  waBroadcasts      WaBroadcast[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pipelineId])
  @@index([pipelineId, order])
}

model Source {
  id   String @id @default(cuid())
  name String @unique

  deals Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LostReason {
  id   String @id @default(cuid())
  name String @unique

  deals Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id          String    @id @default(cuid())
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?

  deals           Deal[]
  campaignContext CampaignContext?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CampaignContext {
  id        String  @id @default(cuid())
  context   String  @db.Text
  isDefault Boolean @default(false)
  triggers  Json    @default("[]")

  campaignId String   @unique
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
}

model Deal {
  id                 String         @id @default(cuid())
  title              String
  value              Decimal?       @db.Decimal(15, 2)
  expectedCloseDate  DateTime?
  expectedReturnDate DateTime?
  closedAt           DateTime?
  sdrActivatedAt     DateTime?
  status             DealStatus     @default(OPEN)
  noShow             Boolean        @default(false)
  noShowAt           DateTime?
  // Origem da reunião agendada — espelha o meetingSource da task MEETING mais recente
  meetingSource      MeetingSource?
  classification     String?
  contaAzulCode      String?
  lostAtStage        String?
  recurrence         String?
  brand              Brand          @default(BGP)

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])

  stageId String
  stage   PipelineStage @relation(fields: [stageId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  sourceId String?
  source   Source? @relation(fields: [sourceId], references: [id])

  lostReasonId String?
  lostReason   LostReason? @relation(fields: [lostReasonId], references: [id])

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  products           DealProduct[]
  tasks              Task[]
  activities         Activity[]
  dealContacts       DealContact[]
  contracts          Contract[]
  scheduledFollowUps ScheduledFollowUp[]
  sentDocuments      SentDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pipelineId])
  @@index([stageId])
  @@index([userId])
  @@index([contactId])
  @@index([organizationId])
  @@index([status])
  @@index([sourceId])
  @@index([pipelineId, stageId])
  @@index([pipelineId, status])
  @@index([status, createdAt])
  @@index([createdAt])
  @@index([brand])
}

model Product {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Decimal @db.Decimal(15, 2)
  sku         String? @unique
  isActive    Boolean @default(true)
  recurrence  String?

  dealProducts DealProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sku])
}

model DealProduct {
  id                String   @id @default(cuid())
  quantity          Int      @default(1)
  unitPrice         Decimal  @db.Decimal(15, 2)
  discount          Decimal  @default(0) @db.Decimal(5, 2)
  discountMonths    Int?
  setupPrice        Decimal? @db.Decimal(15, 2)
  setupInstallments Int?
  recurrenceValue   Decimal? @db.Decimal(15, 2)

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([productId])
}

model DealContact {
  id        String  @id @default(cuid())
  isPrimary Boolean @default(false)

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  createdAt DateTime @default(now())

  @@unique([dealId, contactId])
  @@index([dealId])
  @@index([contactId])
}

model Task {
  id            String         @id @default(cuid())
  title         String
  description   String?
  type          TaskType       @default(OTHER)
  dueDate       DateTime?
  // "UTC" = dueDate é UTC real (convenção timezone-aware correta)
  // "LEGACY" = dueDate é UTC literal representando BRT (dados pré-fix de 2026-04-23)
  // Novos registros sempre "UTC". Legacy migra lazy ao editar.
  dueDateFormat String         @default("UTC")
  completedAt   DateTime?
  status        TaskStatus     @default(PENDING)
  meetingSource MeetingSource?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([dealId])
  @@index([contactId])
  @@index([status])
  @@index([dueDate])
  @@index([userId, status])
}

model Activity {
  id       String       @id @default(cuid())
  type     ActivityType
  content  String
  metadata Json?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([dealId])
  @@index([contactId])
  @@index([type])
  @@index([dealId, createdAt])
}

model CustomField {
  id         String            @id @default(cuid())
  name       String
  fieldType  CustomFieldType
  entity     CustomFieldEntity
  options    Json?
  isRequired Boolean           @default(false)

  values CustomFieldValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entity])
}

model CustomFieldValue {
  id         String  @id @default(cuid())
  entityId   String
  entityType String
  value      String?

  customFieldId String
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customFieldId])
  @@index([entityId, entityType])
  @@index([contactId])
}

model WebhookConfig {
  id       String      @id @default(cuid())
  name     String
  url      String
  type     WebhookType
  events   Json
  secret   String?
  isActive Boolean     @default(true)
  headers  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive])
}

model LeadTracking {
  id          String  @id @default(cuid())
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  referrer    String?
  landingPage String?
  ip          String?
  userAgent   String?

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([contactId])
}

// ─── Marketing: Tags ────────────────────────────────────────────────────────

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6366f1")
  brand Brand  @default(BGP)

  contacts ContactTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brand])
}

model ContactTag {
  id String @id @default(cuid())

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([contactId, tagId])
  @@index([contactId])
  @@index([tagId])
}

// ─── Marketing: Segmentos ───────────────────────────────────────────────────

model Segment {
  id           String  @id @default(cuid())
  name         String
  description  String?
  filters      Json
  isActive     Boolean @default(true)
  contactCount Int     @default(0)
  brand        Brand   @default(BGP)

  emailCampaigns    EmailCampaign[]
  whatsappCampaigns WhatsAppCampaign[]
  waBroadcasts      WaBroadcast[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brand])
}

// ─── Marketing: Lead Scoring ────────────────────────────────────────────────

model LeadScore {
  id                 String          @id @default(cuid())
  score              Int             @default(0)
  engagementLevel    EngagementLevel @default(ENGAGED)
  lastEmailOpenedAt  DateTime?
  lastEmailClickedAt DateTime?

  contactId String  @unique
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@index([score])
  @@index([engagementLevel])
}

model LeadScoreRule {
  id       String                @id @default(cuid())
  name     String
  field    String
  operator SegmentFilterOperator
  value    String
  points   Int
  isActive Boolean               @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Marketing: Import de Contatos ──────────────────────────────────────────

model ContactImport {
  id            String       @id @default(cuid())
  fileName      String
  status        ImportStatus @default(PENDING)
  totalRows     Int          @default(0)
  processedRows Int          @default(0)
  errorRows     Int          @default(0)
  errors        Json?

  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Email Marketing ────────────────────────────────────────────────────────

model EmailTemplate {
  id           String  @id @default(cuid())
  name         String
  subject      String
  htmlContent  String
  jsonContent  Json?
  thumbnailUrl String?
  isActive     Boolean @default(true)
  brand        Brand   @default(BGP)

  campaigns EmailCampaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brand])
}

model EmailCampaign {
  id              String      @id @default(cuid())
  name            String
  subject         String
  fromName        String      @default("BGPGO")
  fromEmail       String      @default("noreply@bertuzzipatrimonial.com.br")
  status          EmailStatus @default(DRAFT)
  scheduledAt     DateTime?
  sentAt          DateTime?
  totalRecipients Int         @default(0)
  brand           Brand       @default(BGP)

  templateId String?
  template   EmailTemplate? @relation(fields: [templateId], references: [id])

  segmentId String?
  segment   Segment? @relation(fields: [segmentId], references: [id])

  filters Json? // filterGroups inline — alternative to segmentId (OR groups format)

  sends EmailSend[]
  links EmailLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([segmentId])
  @@index([brand])
}

model EmailSend {
  id             String          @id @default(cuid())
  status         EmailSendStatus @default(QUEUED)
  sentAt         DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  bouncedAt      DateTime?
  unsubscribedAt DateTime?
  messageId      String?

  emailCampaignId String
  emailCampaign   EmailCampaign @relation(fields: [emailCampaignId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  events EmailEvent[]

  createdAt DateTime @default(now())

  @@unique([emailCampaignId, contactId])
  @@index([emailCampaignId])
  @@index([contactId])
  @@index([status])
  @@index([messageId])
}

model EmailLink {
  id          String @id @default(cuid())
  originalUrl String
  trackingId  String @unique @default(cuid())
  clickCount  Int    @default(0)

  emailCampaignId String
  emailCampaign   EmailCampaign @relation(fields: [emailCampaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([emailCampaignId])
  @@index([trackingId])
}

model EmailEvent {
  id       String @id @default(cuid())
  type     String
  metadata Json?

  emailSendId String
  emailSend   EmailSend @relation(fields: [emailSendId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([emailSendId])
  @@index([type])
}

model UnsubscribeList {
  id        String  @id @default(cuid())
  email     String  @unique
  contactId String?
  reason    String?

  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Automações de Marketing ────────────────────────────────────────────────

model Automation {
  id            String                @id @default(cuid())
  name          String
  description   String?
  status        AutomationStatus      @default(DRAFT)
  triggerType   AutomationTriggerType
  triggerConfig Json
  brand         Brand                 @default(BGP)

  steps       AutomationStep[]
  enrollments AutomationEnrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([brand])
}

model AutomationStep {
  id         String               @id @default(cuid())
  order      Int
  actionType AutomationActionType
  config     Json

  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  nextStepId  String?
  trueStepId  String?
  falseStepId String?

  enrollments AutomationEnrollment[] @relation("CurrentStep")
  logs        AutomationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([automationId])
  @@index([automationId, order])
}

model AutomationEnrollment {
  id           String                     @id @default(cuid())
  status       AutomationEnrollmentStatus @default(ACTIVE)
  enrolledAt   DateTime                   @default(now())
  completedAt  DateTime?
  nextActionAt DateTime?
  metadata     Json?

  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  currentStepId String?
  currentStep   AutomationStep? @relation("CurrentStep", fields: [currentStepId], references: [id])

  logs AutomationLog[]

  @@index([automationId])
  @@index([contactId])
  @@index([status])
  @@index([nextActionAt])
  @@index([automationId, status])
}

model AutomationLog {
  id         String @id @default(cuid())
  actionType String
  result     Json?

  enrollmentId String
  enrollment   AutomationEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  stepId String
  step   AutomationStep @relation(fields: [stepId], references: [id])

  executedAt DateTime @default(now())

  @@index([enrollmentId])
  @@index([stepId])
}

// ─── Notification Config ────────────────────────────────────────────────────

model NotificationConfig {
  id    String @id @default(cuid())
  key   String @unique // e.g. "deal_won_emails", "deal_won_enabled"
  value String @db.Text // JSON or plain text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ─── Contracts ──────────────────────────────────────────────────────────────

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  SIGNED
  COMPLETED
  CANCELLED
}

model Contract {
  id     String         @id @default(cuid())
  status ContractStatus @default(DRAFT)

  // Link to deal
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id])

  // Client data (snapshot — copied from deal/contact/org at creation)
  razaoSocial        String
  nomeFantasia       String?
  cnpj               String
  endereco           String
  representante      String
  cpfRepresentante   String
  emailRepresentante String
  emailFinanceiro    String?

  // Product
  produto                  String // bgp-go-i, bgp-go-ii, bgp-go-iii, bgp-bi, bi-personalizado, bgp-strategy, bgp-valuation, brand-growth
  strategyModules          Json? // { crescimento: bool, redesenho: bool, recuperacao: bool }
  biOrigemDados            String?
  biQtdLicencas            String?
  biQtdTelasPersonalizadas String?

  // Financial
  valorMensal           Decimal  @db.Decimal(15, 2)
  diaVencimento         Int
  dataInicio            DateTime
  formaPagamento        String   @default("boleto")
  valorImplementacao    Decimal? @db.Decimal(15, 2)
  implementacaoParcelas Int?
  descontoMeses         Int?
  descontoPercentual    Decimal? @db.Decimal(5, 2)

  // Additional
  observacao String? @db.Text
  linkReadAi String?

  // Witnesses
  testemunha1Nome  String?
  testemunha1Cpf   String?
  testemunha1Email String?
  testemunha2Nome  String?
  testemunha2Cpf   String?
  testemunha2Email String?

  // Autentique
  autentiqueDocumentId String?
  autentiqueSentAt     DateTime?
  autentiqueSignedAt   DateTime?

  // Generated HTML (cached for re-viewing)
  htmlContent String? @db.Text

  signatures ContractSignatureRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([status])
}

model ContractSignatureRecord {
  id          String    @id @default(cuid())
  contractId  String
  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  signerName  String
  signerEmail String
  signerRole  String // contratada, contratante, testemunha1, testemunha2
  status      String    @default("pending") // pending, signed
  signedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([contractId])
}

model ContractWitness {
  id    String @id @default(cuid())
  name  String
  cpf   String
  email String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model SentDocument {
  id                   String    @id @default(cuid())
  autentiqueDocumentId String
  documentName         String
  documentType         String    @default("contract") // "contract", "aditivo", "distrato"
  signerEmails         String // comma-separated emails
  status               String    @default("pending") // "pending", "signed"
  signedCount          Int       @default(0)
  totalSigners         Int       @default(0)
  lastCheckedAt        DateTime?
  metadata             Json? // full Autentique response with signer details
  dealId               String?
  deal                 Deal?     @relation(fields: [dealId], references: [id])
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([dealId])
  @@index([status])
}

// ─── WhatsApp / Conversas ───────────────────────────────────────────────────

enum WhatsAppConnectionStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
}

enum WaCampaignStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

enum WaCampaignContactStatus {
  PENDING
  SENT
  ERROR
  SKIPPED
}

enum MessageSender {
  CLIENT
  BOT
  HUMAN
}

enum FollowUpTone {
  CASUAL
  REFORCO
  ENCERRAMENTO
}

model MeetingReminderStep {
  id            String  @id @default(cuid())
  minutesBefore Int // 240, 120, 60, 30, 15
  enabled       Boolean @default(true)
  message       String  @db.Text // template with {{nome}}, {{data}}, {{hora}}, {{falta}}

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([minutesBefore])
  @@index([minutesBefore])
}

model WhatsAppConfig {
  id                       String                   @id @default(cuid())
  zapiInstanceId           String                   @default("")
  zapiToken                String                   @default("")
  zapiClientToken          String                   @default("")
  baseUrl                  String                   @default("http://localhost:3001")
  companyName              String                   @default("")
  companyPhone             String                   @default("")
  meetingLink              String                   @default("")
  openaiApiKey             String                   @default("")
  botEnabled               Boolean                  @default(true)
  botSystemPrompt          String?                  @db.Text
  welcomeMessage           String?                  @db.Text
  connectionStatus         WhatsAppConnectionStatus @default(DISCONNECTED)
  followUpEnabled          Boolean                  @default(false)
  leadQualificationEnabled Boolean                  @default(true)
  sdrAutoMessageEnabled    Boolean                  @default(true)
  meetingReminderEnabled   Boolean                  @default(true)
  cadenceEnabled           Boolean                  @default(false)
  botPhoneNumber           String?
  readAiApiKey             String?

  dailyMessageLimit Int       @default(200)
  warmupEnabled     Boolean   @default(false)
  warmupStartDate   DateTime?

  // SDR Identity
  botName    String @default("Bia")
  botCompany String @default("Bertuzzi Patrimonial")

  // Conversation behavior
  conversationRules  String? @db.Text
  funnelInstructions String? @db.Text

  // Prompt blocks (WABA bot — wa/botService.ts). null = usa default do código.
  // botOpeningPrompt/botErrorFallback aceitam placeholders {botName},{botCompany}; errorFallback também {nome}.
  botOpeningPrompt String? @db.Text
  botMessageFormat String? @db.Text
  botKpi           String? @db.Text
  botErrorFallback String? @db.Text

  // Prompt por etapa do funil (injetado via buildDealContext)
  stagePromptMeetingScheduled String? @db.Text
  stagePromptProposalSent     String? @db.Text
  stagePromptWaitingData      String? @db.Text
  stagePromptWaitingSignature String? @db.Text

  // Parâmetros da chamada OpenAI (null = default do código)
  aiModel            String?
  aiTemperature      Float?
  aiMaxTokens        Int?
  botDebounceSeconds Int?

  // Follow-up tone instructions (null = usa texto padrão do código)
  followUpToneCasual       String? @db.Text
  followUpToneReforco      String? @db.Text
  followUpToneEncerramento String? @db.Text

  // Cold contact limit (stop follow-ups after N messages with no reply)
  coldContactMaxMessages Int @default(2)

  // Business hours (Brasília)
  businessHoursStart       Int @default(8)
  businessHoursEndWeekday  Int @default(18)
  businessHoursEndSaturday Int @default(12)

  // Custom name blacklist — termos adicionais à baseline hardcoded do nameSanitizer.
  // Vazio = usa só o baseline. Aditivo: nunca remove termos do baseline.
  nameBlacklist String[] @default([])

  followUpSteps WhatsAppFollowUpStep[]
  botProducts   BotProduct[]
  botObjections BotObjection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BotProduct {
  id             String  @id @default(cuid())
  name           String
  description    String? @db.Text
  priceRange     String?
  targetAudience String? @db.Text
  differentials  String? @db.Text
  order          Int     @default(0)
  isActive       Boolean @default(true)

  configId String
  config   WhatsAppConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([configId])
  @@index([configId, order])
}

model BotObjection {
  id        String @id @default(cuid())
  objection String @db.Text
  response  String @db.Text
  order     Int    @default(0)

  configId String
  config   WhatsAppConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([configId])
  @@index([configId, order])
}

model WhatsAppDailyVolume {
  id        String   @id @default(cuid())
  date      DateTime @unique
  campaign  Int      @default(0)
  followUp  Int      @default(0)
  reminder  Int      @default(0)
  total     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([date])
}

model WhatsAppFollowUpStep {
  id           String       @id @default(cuid())
  order        Int
  delayMinutes Int          @default(30)
  tone         FollowUpTone @default(CASUAL)

  configId String
  config   WhatsAppConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([configId])
  @@index([configId, order])
}

model WhatsAppConversation {
  id                  String    @id @default(cuid())
  phone               String    @unique
  pushName            String?
  isActive            Boolean   @default(true)
  meetingBooked       Boolean   @default(false)
  needsHumanAttention Boolean   @default(false)
  status              String    @default("open") // open, closed
  lastMessageAt       DateTime?
  lastReadAt          DateTime?
  optedOut            Boolean   @default(false)
  optedOutAt          DateTime?

  // Cloud API: janela de 24h para mensagens livres (expira 24h após última msg do cliente)
  cloudWindowExpiresAt DateTime?

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  assignedUserId String?
  assignedUser   User?   @relation("WhatsAppConversationAssignee", fields: [assignedUserId], references: [id])

  messages           WhatsAppMessage[]
  aiHistory          WhatsAppAIHistory[]
  followUpState      WhatsAppFollowUpState?
  scheduledFollowUps ScheduledFollowUp[]
  cloudMessages      CloudWaMessageLog[]    @relation("CloudMessages")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([contactId])
  @@index([assignedUserId])
  @@index([lastMessageAt])
  @@index([isActive])
  @@index([status])
}

model WhatsAppMessage {
  id           String        @id @default(cuid())
  sender       MessageSender
  text         String        @db.Text
  externalId   String?
  isFollowUp   Boolean       @default(false)
  followUpStep Int?
  metadata     Json?
  delivered    Boolean       @default(true)
  editedAt     DateTime?

  conversationId String
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderUserId String?
  senderUser   User?   @relation("WhatsAppMessageSender", fields: [senderUserId], references: [id])

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([conversationId, sender, createdAt])
  @@index([conversationId, delivered])
  @@index([externalId])
}

model WhatsAppAIHistory {
  id      String @id @default(cuid())
  role    String
  content String @db.Text

  conversationId String
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

model WhatsAppFollowUpState {
  id                    String    @id @default(cuid())
  followUpCount         Int       @default(0)
  lastFollowUpAt        DateTime?
  lastBotMessageAt      DateTime?
  respondedSinceLastBot Boolean   @default(false)
  paused                Boolean   @default(false)

  conversationId String               @unique
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId])
}

model ScheduledFollowUp {
  id             String                @id @default(cuid())
  type           String                @default("FOLLOW_UP") // FOLLOW_UP, MEETING_REMINDER
  conversationId String?
  conversation   WhatsAppConversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  dealId         String?
  deal           Deal?                 @relation(fields: [dealId], references: [id], onDelete: Cascade)
  meetingId      String? // CalendlyEvent ID for meeting reminders
  stepNumber     Int // 1, 2, 3...
  label          String? // "4 horas antes", "Follow-up #1 Casual", etc.
  tone           String? // CASUAL, REFORCO, ENCERRAMENTO (for follow-ups)
  delayMinutes   Int
  scheduledAt    DateTime // When this will fire
  status         String                @default("PENDING") // PENDING, SENT, CANCELLED
  sentAt         DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime              @default(now())

  @@unique([conversationId, stepNumber, type])
  @@index([conversationId])
  @@index([dealId])
  @@index([meetingId])
  @@index([conversationId, status])
  @@index([scheduledAt])
}

model WhatsAppCampaign {
  id          String           @id @default(cuid())
  name        String
  message     String           @db.Text
  status      WaCampaignStatus @default(DRAFT)
  startedAt   DateTime?
  completedAt DateTime?

  stageId String?
  stage   PipelineStage? @relation(fields: [stageId], references: [id])

  segmentId String?
  segment   Segment? @relation(fields: [segmentId], references: [id])

  contacts WhatsAppCampaignContact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([stageId])
  @@index([segmentId])
}

// ─── WhatsApp Message Templates ─────────────────────────────────────────────

model WhatsAppMessageTemplate {
  id       String @id @default(cuid())
  name     String @unique // shortcut name like "boas-vindas", "reuniao"
  category String @default("geral") // categorization
  content  String @db.Text // the message text with placeholders like {{nome}}, {{empresa}}

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([category])
}

// ─── Calendly Integration ──────────────────────────────────────────────────

model CalendlyConfig {
  id              String  @id @default(cuid())
  apiKey          String  @default("")
  webhookSecret   String  @default("")
  isActive        Boolean @default(true)
  organizationUri String  @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CalendlyEvent {
  id              String   @id @default(cuid())
  calendlyEventId String   @unique
  eventType       String
  inviteeEmail    String
  inviteeName     String?
  hostEmail       String?
  hostName        String?
  startTime       DateTime
  endTime         DateTime
  status          String   @default("active")

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  dealId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([inviteeEmail])
  @@index([calendlyEventId])
  @@index([contactId])
}

model WhatsAppCampaignContact {
  id     String                  @id @default(cuid())
  phone  String
  status WaCampaignContactStatus @default(PENDING)
  sentAt DateTime?
  error  String?

  campaignId String
  campaign   WhatsAppCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([campaignId])
  @@index([campaignId, status])
}

// ─── Read.ai Integration ──────────────────────────────────────────────────

model ReadAiMeeting {
  id           String    @id @default(cuid())
  sessionId    String    @unique
  title        String?
  summary      String?   @db.Text
  transcript   String?   @db.Text
  actionItems  Json?
  topics       Json?
  duration     Int?
  meetingDate  DateTime?
  participants Json?
  rawData      Json?

  /// Relatório estruturado gerado por IA (10 campos de análise de vendas)
  aiAnalysis   Json?
  aiAnalyzedAt DateTime?

  dealId    String?
  contactId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([contactId])
  @@index([sessionId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// WHATSAPP CLOUD API (API OFICIAL)
// Modelos separados do sistema Z-API legado. Prefixo "Cloud" em todos os nomes.
// Quando a migração estiver completa, os modelos sem prefixo (Z-API) serão removidos.
// ═══════════════════════════════════════════════════════════════════════════════

enum CloudWaTemplateStatus {
  PENDING
  APPROVED
  REJECTED
  PAUSED
  DISABLED
}

enum CloudWaTemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum CloudWaMessageStatus {
  PENDING // Sent to Meta, waiting for callback
  SENT // Meta accepted (single check)
  DELIVERED // Reached device (double check)
  READ // Read (blue checks)
  FAILED // Delivery failed
}

model CloudWaConfig {
  id String @id @default(cuid())

  // ── Credenciais Cloud API ──
  phoneNumberId String @default("") // ID do número no Meta (não é o número em si)
  wabaId        String @default("") // WhatsApp Business Account ID
  accessToken   String @default("") // System User token permanente
  appSecret     String @default("") // Para verificar assinatura dos webhooks
  verifyToken   String @default("") // Token customizado para setup do webhook
  twoStepPin    String @default("") // PIN 2FA de 6 dígitos
  displayPhone  String @default("") // Número de telefone legível (ex: +5511999999999)

  // ── Status ──
  isActive      Boolean @default(false) // true = Cloud API é o canal ativo
  qualityRating String  @default("GREEN") // GREEN, YELLOW, RED
  messagingTier String  @default("TIER_1") // TIER_1, TIER_2, TIER_3, UNLIMITED
  phoneStatus   String  @default("PENDING_SETUP") // CONNECTED, FLAGGED, RESTRICTED, PENDING_SETUP

  // ── Limites ──
  dailyMessageLimit  Int   @default(250) // Limite por tier
  dailySpendLimitBRL Float @default(40.0) // Limite de gasto diário em R$ (0 = sem limite)

  // ── Webhook ──
  webhookUrl String @default("") // URL configurada para receber callbacks

  // ── Features ──
  wabaMeetingReminderEnabled Boolean @default(false) // Lembretes de reunião via WABA (desativado por padrão)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CloudWaTemplate {
  id String @id @default(cuid())

  // ── Identificação ──
  name     String // Nome do template (lowercase, underscores)
  language String                  @default("pt_BR")
  category CloudWaTemplateCategory
  status   CloudWaTemplateStatus   @default(PENDING)

  // ── IDs da Meta ──
  metaTemplateId String? // ID retornado pela Meta após criação
  qualityScore   String? // GREEN, YELLOW, RED (após aprovação)
  rejectedReason String? // Motivo da rejeição (se houver)

  // ── Conteúdo ──
  headerType    String? // TEXT, IMAGE, VIDEO, DOCUMENT, null
  headerContent String? @db.Text // Texto do header ou URL de exemplo
  body          String  @db.Text // Corpo do template com {{1}}, {{2}}...
  footer        String? // Texto do footer (estático)
  buttons       Json? // Array de botões [{type, text, url?, payload?}]

  // Payload completo de components enviado à Meta (para templates complexos: carousel, LTO, etc.)
  components Json?

  // ── Exemplos (exigidos pela Meta para aprovação) ──
  bodyExamples  Json? // Ex: [["João", "previdência"]]
  headerExample String? // Ex: URL da imagem de exemplo

  // ── Mapeamento de variáveis ──
  variableMapping Json? // Ex: [{"var": "{{1}}", "source": "contact.name"}, {"var": "{{2}}", "source": "meeting.time"}]

  // ── Controle ──
  editsRemaining Int       @default(10) // Max 10 edições por 30 dias (APPROVED)
  lastEditedAt   DateTime?

  // ── Relações v2 ──
  waBroadcasts WaBroadcast[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, language])
  @@index([status])
  @@index([category])
  @@index([metaTemplateId])
}

model CloudWaMessageLog {
  id String @id @default(cuid())

  // ── Identificação ──
  waMessageId String @unique // wamid.HBgN... (ID da Meta)
  direction   String // INBOUND ou OUTBOUND
  phone       String // Número do contato (sem @s.whatsapp.net)

  // ── Conteúdo ──
  type             String // text, template, image, video, audio, document, interactive, reaction
  body             String? @db.Text // Texto da mensagem (ou caption)
  mediaUrl         String? // URL da mídia (se houver)
  mediaId          String? // Media ID da Meta (expira em 30 dias)
  templateName     String? // Nome do template usado (se OUTBOUND template)
  contextMessageId String? // ID da mensagem sendo respondida (reply/quote)
  metadata         Json? // Payload completo para debug

  // ── Status de entrega (atualizado via webhook) ──
  status       CloudWaMessageStatus @default(PENDING)
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failedAt     DateTime?
  errorCode    String? // Código de erro Meta (ex: 131047)
  errorMessage String? // Mensagem de erro

  // ── Vínculo com remetente (para mensagens OUTBOUND enviadas do inbox) ──
  sentByUserId String?
  sentByUser   User?   @relation("CloudWaMessageSender", fields: [sentByUserId], references: [id])

  // ── Vínculo com conversa ──
  conversationId String?
  conversation   WhatsAppConversation? @relation("CloudMessages", fields: [conversationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone, createdAt])
  @@index([conversationId])
  @@index([status])
  @@index([direction, createdAt])
  @@index([sentByUserId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// WHATSAPP CLOUD API v2 — MÓDULO NOVO (independente do Z-API)
// Prefixo "Wa" em todos os nomes. Quando a Z-API for desligada, estes ficam.
// ═══════════════════════════════════════════════════════════════════════════════

enum WaMessageDirection {
  INBOUND
  OUTBOUND
}

enum WaMessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  LOCATION
  INTERACTIVE_BUTTONS
  INTERACTIVE_LIST
  TEMPLATE
  REACTION
  UNKNOWN
}

enum WaMessageStatus {
  WA_PENDING
  WA_SENT
  WA_DELIVERED
  WA_READ
  WA_FAILED
}

enum WaMessageSender {
  WA_CLIENT
  WA_BOT
  WA_HUMAN
  WA_SYSTEM
}

enum WaConversationStatus {
  WA_OPEN
  WA_CLOSED
  WA_ARCHIVED
}

enum WaBroadcastStatus {
  WA_DRAFT
  WA_SCHEDULED
  WA_SENDING
  WA_PAUSED
  WA_COMPLETED
}

enum WaBroadcastContactStatus {
  WA_BC_PENDING
  WA_BC_SENT
  WA_BC_DELIVERED
  WA_BC_READ
  WA_BC_FAILED
  WA_BC_SKIPPED
}

// ── Conversa (independente de WhatsAppConversation) ──────────────────────────

model WaConversation {
  id    String @id @default(cuid())
  phone String @unique

  pushName String?
  status   WaConversationStatus @default(WA_OPEN)

  // ── Janela de 24h ──
  windowExpiresAt     DateTime? // null = sem janela, só template
  lastClientMessageAt DateTime? // última msg do cliente (para cálculo da janela)

  // ── Roteamento bot/humano ──
  isActive            Boolean @default(true)
  needsHumanAttention Boolean @default(false)
  meetingBooked       Boolean @default(false)

  // ── Opt-out ──
  optedOut   Boolean   @default(false)
  optedOutAt DateTime?

  // ── Timestamps ──
  lastMessageAt DateTime? // última msg (qualquer direção)
  lastReadAt    DateTime? // última vez que agente visualizou

  // ── Relações ──
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  assignedUserId String?
  assignedUser   User?   @relation("WaConversationAssignee", fields: [assignedUserId], references: [id])

  messages      WaMessage[]
  aiHistory     WaAIHistory[]
  followUpState WaFollowUpState?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([contactId])
  @@index([assignedUserId])
  @@index([status])
  @@index([lastMessageAt])
  @@index([windowExpiresAt])
}

// ── Mensagem unificada (inbound + outbound, todos os tipos) ─────────────────

model WaMessage {
  id String @id @default(cuid())

  // ── Identificação Meta ──
  waMessageId String?            @unique // wamid.HBgN... (ID da Meta)
  direction   WaMessageDirection
  senderType  WaMessageSender

  // ── Conteúdo ──
  type          WaMessageType @default(TEXT)
  body          String?       @db.Text
  mediaUrl      String?
  mediaId       String? // Media ID da Meta (expira 30 dias)
  mediaFileName String?
  mediaMimeType String?

  // ── Mensagens interativas ──
  interactiveData Json? // OUTBOUND: definição botões/lista; INBOUND: opção selecionada

  // ── Template ──
  templateName   String?
  templateParams Json?

  // ── Reply context ──
  replyToMessageId String? // waMessageId da msg sendo respondida

  // ── Delivery tracking ──
  status       WaMessageStatus @default(WA_PENDING)
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failedAt     DateTime?
  errorCode    String?
  errorMessage String?

  // ── Follow-up ──
  isFollowUp   Boolean @default(false)
  followUpStep Int?

  // ── Debug ──
  metadata Json?

  // ── Relações ──
  conversationId String
  conversation   WaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderUserId String?
  senderUser   User?   @relation("WaMessageSender", fields: [senderUserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId, createdAt])
  @@index([conversationId, senderType, createdAt])
  @@index([waMessageId])
  @@index([status])
  @@index([direction, createdAt])
}

// ── Histórico IA (contexto OpenAI) ──────────────────────────────────────────

model WaAIHistory {
  id      String @id @default(cuid())
  role    String // system, user, assistant
  content String @db.Text

  conversationId String
  conversation   WaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

// ── Estado de follow-up ─────────────────────────────────────────────────────

model WaFollowUpState {
  id                    String    @id @default(cuid())
  followUpCount         Int       @default(0)
  lastFollowUpAt        DateTime?
  lastBotMessageAt      DateTime?
  respondedSinceLastBot Boolean   @default(false)
  paused                Boolean   @default(false)

  conversationId String         @unique
  conversation   WaConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId])
}

// ── Broadcast (campanha via template aprovado) ──────────────────────────────

model WaBroadcast {
  id     String            @id @default(cuid())
  name   String
  status WaBroadcastStatus @default(WA_DRAFT)
  brand  Brand             @default(BGP)

  // ── Template obrigatório (Meta exige para bulk) ──
  templateId     String?
  template       CloudWaTemplate? @relation(fields: [templateId], references: [id])
  templateParams Json? // params default

  // ── Targeting ──
  segmentId String?
  segment   Segment? @relation(fields: [segmentId], references: [id])

  stageId String?
  stage   PipelineStage? @relation(fields: [stageId], references: [id])

  stageIds   Json? // Array de stageIds quando multi-select
  dealStatus String? // OPEN | WON | LOST — filtro de andamento usado

  // ── Scheduling ──
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  pausedAt    DateTime?

  // ── Stats (denormalizados) ──
  totalContacts  Int @default(0)
  sentCount      Int @default(0)
  deliveredCount Int @default(0)
  readCount      Int @default(0)
  clickedCount   Int @default(0)
  failedCount    Int @default(0)

  contacts WaBroadcastContact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([scheduledAt])
  @@index([brand])
}

model WaBroadcastContact {
  id        String                   @id @default(cuid())
  phone     String
  contactId String?
  status    WaBroadcastContactStatus @default(WA_BC_PENDING)

  waMessageId    String? // link para WaMessage após envio
  templateParams Json? // override por contato

  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  clickedAt   DateTime? // Rastreia clique no botão CTA URL
  failedAt    DateTime?
  error       String?

  broadcastId String
  broadcast   WaBroadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([broadcastId])
  @@index([broadcastId, status])
  @@index([phone])
  @@index([waMessageId])
}

// ─── Duplicate Detection ───────────────────────────────────────────────────────

model DuplicateAlert {
  id         String   @id @default(cuid())
  contactAId String // contato recém-criado (ex: via Calendly)
  contactBId String // possível duplicata (ex: via GreatPages)
  reason     String // ex: "Mesmo nome, criado 27s antes"
  status     String   @default("PENDING") // PENDING | MERGED | DISMISSED
  createdAt  DateTime @default(now())

  @@index([status])
}

// ─── Daily Report — Tráfego Pago (Meta Ads / Google Ads) ────────────────────

enum AdSource {
  META_ADS
  GOOGLE_ADS
}

model AdSpend {
  id              String   @id @default(cuid())
  date            DateTime @db.Date
  source          AdSource
  campaignId      String
  campaignName    String
  spend           Decimal  @db.Decimal(12, 2)
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  leads           Int      @default(0)
  conversions     Int      @default(0)
  conversionValue Decimal  @default(0) @db.Decimal(12, 2)
  meta            Json?
  syncedAt        DateTime @default(now())

  @@unique([date, source, campaignId])
  @@index([date, source])
  @@index([campaignName])
  @@map("ad_spend")
}
