// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  SELLER
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum TaskType {
  CALL
  EMAIL
  MEETING
  VISIT
  OTHER
}

enum TaskStatus {
  PENDING
  COMPLETED
  OVERDUE
}

enum ActivityType {
  NOTE
  EMAIL
  CALL
  MEETING
  STAGE_CHANGE
  STATUS_CHANGE
  TASK_COMPLETED
  DEAL_CREATED
  WEBHOOK_RECEIVED
  EMAIL_SENT
  EMAIL_OPENED
  TAG_ADDED
  TAG_REMOVED
  AUTOMATION_ENROLLED
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  MULTISELECT
}

enum CustomFieldEntity {
  CONTACT
  ORGANIZATION
  DEAL
}

enum WebhookType {
  INCOMING
  OUTGOING
}

enum EngagementLevel {
  ENGAGED
  INTERMEDIATE
  DISENGAGED
}

enum SegmentFilterOperator {
  EQUALS
  CONTAINS
  GREATER_THAN
  LESS_THAN
  IN
  NOT_IN
  BETWEEN
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum EmailStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

enum EmailSendStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  SPAM
  UNSUBSCRIBED
}

enum AutomationStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum AutomationTriggerType {
  TAG_ADDED
  TAG_REMOVED
  STAGE_CHANGED
  CONTACT_CREATED
  FIELD_UPDATED
  DATE_BASED
}

enum AutomationActionType {
  ADD_TAG
  REMOVE_TAG
  SEND_EMAIL
  SEND_WHATSAPP
  SEND_WHATSAPP_AI
  WAIT
  UPDATE_FIELD
  MOVE_PIPELINE_STAGE
  CONDITION
  MARK_LOST
}

enum AutomationEnrollmentStatus {
  ACTIVE
  COMPLETED
  PAUSED
  FAILED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Team {
  id          String  @id @default(cuid())
  name        String
  description String?

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(SELLER)
  avatarUrl String?
  phone     String?
  isActive  Boolean  @default(true)

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id])

  deals      Deal[]
  tasks      Task[]
  activities Activity[]

  assignedConversations WhatsAppConversation[] @relation("WhatsAppConversationAssignee")
  sentWhatsAppMessages  WhatsAppMessage[]      @relation("WhatsAppMessageSender")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([teamId])
}

model Organization {
  id        String  @id @default(cuid())
  name      String
  cnpj      String? @unique
  segment   String?
  website   String?
  phone     String?
  address   String?
  instagram String?
  email     String?
  notes     String?

  contacts Contact[]
  deals    Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cnpj])
  @@index([name])
}

model Contact {
  id        String    @id @default(cuid())
  name      String
  email     String?
  phone     String?
  position  String?
  birthday  DateTime?
  instagram String?
  notes     String?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  deals                 Deal[]
  tasks                 Task[]
  activities            Activity[]
  customFieldValues     CustomFieldValue[]
  leadTrackings         LeadTracking[]
  dealContacts          DealContact[]
  tags                  ContactTag[]
  leadScore             LeadScore?
  emailSends            EmailSend[]
  automationEnrollments AutomationEnrollment[]
  whatsappConversations WhatsAppConversation[]
  calendlyEvents        CalendlyEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([organizationId])
  @@index([name])
}

model Pipeline {
  id        String  @id @default(cuid())
  name      String
  isDefault Boolean @default(false)

  stages PipelineStage[]
  deals  Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PipelineStage {
  id    String  @id @default(cuid())
  name  String
  order Int
  color String?

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  deals             Deal[]
  whatsappCampaigns WhatsAppCampaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pipelineId])
  @@index([pipelineId, order])
}

model Source {
  id   String @id @default(cuid())
  name String @unique

  deals Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LostReason {
  id   String @id @default(cuid())
  name String @unique

  deals Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id          String    @id @default(cuid())
  name        String
  description String?
  startDate   DateTime?
  endDate     DateTime?

  deals           Deal[]
  campaignContext CampaignContext?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CampaignContext {
  id        String  @id @default(cuid())
  context   String  @db.Text
  isDefault Boolean @default(false)
  triggers  Json    @default("[]")

  campaignId String   @unique
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaignId])
}

model Deal {
  id                String     @id @default(cuid())
  title             String
  value             Decimal?   @db.Decimal(15, 2)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  status            DealStatus @default(OPEN)
  classification    String?
  contaAzulCode     String?
  lostAtStage       String?
  recurrence        String?

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])

  stageId String
  stage   PipelineStage @relation(fields: [stageId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  sourceId String?
  source   Source? @relation(fields: [sourceId], references: [id])

  lostReasonId String?
  lostReason   LostReason? @relation(fields: [lostReasonId], references: [id])

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  products     DealProduct[]
  tasks        Task[]
  activities   Activity[]
  dealContacts DealContact[]
  contracts    Contract[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pipelineId])
  @@index([stageId])
  @@index([userId])
  @@index([contactId])
  @@index([organizationId])
  @@index([status])
  @@index([sourceId])
  @@index([pipelineId, stageId])
  @@index([pipelineId, status])
  @@index([status, createdAt])
  @@index([createdAt])
}

model Product {
  id          String  @id @default(cuid())
  name        String
  description String?
  price       Decimal @db.Decimal(15, 2)
  sku         String? @unique
  isActive    Boolean @default(true)
  recurrence  String?

  dealProducts DealProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sku])
}

model DealProduct {
  id        String  @id @default(cuid())
  quantity  Int     @default(1)
  unitPrice Decimal @db.Decimal(15, 2)
  discount  Decimal @default(0) @db.Decimal(5, 2)
  discountMonths  Int?
  setupPrice      Decimal? @db.Decimal(15, 2)
  setupInstallments Int?
  recurrenceValue Decimal? @db.Decimal(15, 2)

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([productId])
}

model DealContact {
  id        String  @id @default(cuid())
  isPrimary Boolean @default(false)

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  createdAt DateTime @default(now())

  @@unique([dealId, contactId])
  @@index([dealId])
  @@index([contactId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  type        TaskType   @default(OTHER)
  dueDate     DateTime?
  completedAt DateTime?
  status      TaskStatus @default(PENDING)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([dealId])
  @@index([contactId])
  @@index([status])
  @@index([dueDate])
  @@index([userId, status])
}

model Activity {
  id       String       @id @default(cuid())
  type     ActivityType
  content  String
  metadata Json?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([dealId])
  @@index([contactId])
  @@index([type])
  @@index([dealId, createdAt])
}

model CustomField {
  id         String            @id @default(cuid())
  name       String
  fieldType  CustomFieldType
  entity     CustomFieldEntity
  options    Json?
  isRequired Boolean           @default(false)

  values CustomFieldValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entity])
}

model CustomFieldValue {
  id         String  @id @default(cuid())
  entityId   String
  entityType String
  value      String?

  customFieldId String
  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customFieldId])
  @@index([entityId, entityType])
  @@index([contactId])
}

model WebhookConfig {
  id       String      @id @default(cuid())
  name     String
  url      String
  type     WebhookType
  events   Json
  secret   String?
  isActive Boolean     @default(true)
  headers  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive])
}

model LeadTracking {
  id          String  @id @default(cuid())
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  referrer    String?
  landingPage String?
  ip          String?
  userAgent   String?

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([contactId])
}

// ─── Marketing: Tags ────────────────────────────────────────────────────────

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6366f1")

  contacts ContactTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactTag {
  id String @id @default(cuid())

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([contactId, tagId])
  @@index([contactId])
  @@index([tagId])
}

// ─── Marketing: Segmentos ───────────────────────────────────────────────────

model Segment {
  id           String  @id @default(cuid())
  name         String
  description  String?
  filters      Json
  isActive     Boolean @default(true)
  contactCount Int     @default(0)

  emailCampaigns    EmailCampaign[]
  whatsappCampaigns WhatsAppCampaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Marketing: Lead Scoring ────────────────────────────────────────────────

model LeadScore {
  id                 String          @id @default(cuid())
  score              Int             @default(0)
  engagementLevel    EngagementLevel @default(ENGAGED)
  lastEmailOpenedAt  DateTime?
  lastEmailClickedAt DateTime?

  contactId String  @unique
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@index([score])
  @@index([engagementLevel])
}

model LeadScoreRule {
  id       String                @id @default(cuid())
  name     String
  field    String
  operator SegmentFilterOperator
  value    String
  points   Int
  isActive Boolean               @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Marketing: Import de Contatos ──────────────────────────────────────────

model ContactImport {
  id            String       @id @default(cuid())
  fileName      String
  status        ImportStatus @default(PENDING)
  totalRows     Int          @default(0)
  processedRows Int          @default(0)
  errorRows     Int          @default(0)
  errors        Json?

  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Email Marketing ────────────────────────────────────────────────────────

model EmailTemplate {
  id           String  @id @default(cuid())
  name         String
  subject      String
  htmlContent  String
  jsonContent  Json?
  thumbnailUrl String?
  isActive     Boolean @default(true)

  campaigns EmailCampaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailCampaign {
  id              String      @id @default(cuid())
  name            String
  subject         String
  fromName        String      @default("BGPGO")
  fromEmail       String      @default("noreply@bertuzzipatrimonial.com.br")
  status          EmailStatus @default(DRAFT)
  scheduledAt     DateTime?
  sentAt          DateTime?
  totalRecipients Int         @default(0)

  templateId String?
  template   EmailTemplate? @relation(fields: [templateId], references: [id])

  segmentId String?
  segment   Segment? @relation(fields: [segmentId], references: [id])

  sends EmailSend[]
  links EmailLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([segmentId])
}

model EmailSend {
  id             String          @id @default(cuid())
  status         EmailSendStatus @default(QUEUED)
  sentAt         DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  bouncedAt      DateTime?
  unsubscribedAt DateTime?
  messageId      String?

  emailCampaignId String
  emailCampaign   EmailCampaign @relation(fields: [emailCampaignId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  events EmailEvent[]

  createdAt DateTime @default(now())

  @@unique([emailCampaignId, contactId])
  @@index([emailCampaignId])
  @@index([contactId])
  @@index([status])
  @@index([messageId])
}

model EmailLink {
  id          String @id @default(cuid())
  originalUrl String
  trackingId  String @unique @default(cuid())
  clickCount  Int    @default(0)

  emailCampaignId String
  emailCampaign   EmailCampaign @relation(fields: [emailCampaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([emailCampaignId])
  @@index([trackingId])
}

model EmailEvent {
  id       String @id @default(cuid())
  type     String
  metadata Json?

  emailSendId String
  emailSend   EmailSend @relation(fields: [emailSendId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([emailSendId])
  @@index([type])
}

model UnsubscribeList {
  id        String  @id @default(cuid())
  email     String  @unique
  contactId String?
  reason    String?

  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Automações de Marketing ────────────────────────────────────────────────

model Automation {
  id            String                @id @default(cuid())
  name          String
  description   String?
  status        AutomationStatus      @default(DRAFT)
  triggerType   AutomationTriggerType
  triggerConfig Json

  steps       AutomationStep[]
  enrollments AutomationEnrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model AutomationStep {
  id         String               @id @default(cuid())
  order      Int
  actionType AutomationActionType
  config     Json

  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  nextStepId  String?
  trueStepId  String?
  falseStepId String?

  enrollments AutomationEnrollment[] @relation("CurrentStep")
  logs        AutomationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([automationId])
  @@index([automationId, order])
}

model AutomationEnrollment {
  id           String                     @id @default(cuid())
  status       AutomationEnrollmentStatus @default(ACTIVE)
  enrolledAt   DateTime                   @default(now())
  completedAt  DateTime?
  nextActionAt DateTime?
  metadata     Json?

  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id])

  currentStepId String?
  currentStep   AutomationStep? @relation("CurrentStep", fields: [currentStepId], references: [id])

  logs AutomationLog[]

  @@index([automationId])
  @@index([contactId])
  @@index([status])
  @@index([nextActionAt])
  @@index([automationId, status])
}

model AutomationLog {
  id         String @id @default(cuid())
  actionType String
  result     Json?

  enrollmentId String
  enrollment   AutomationEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  stepId String
  step   AutomationStep @relation(fields: [stepId], references: [id])

  executedAt DateTime @default(now())

  @@index([enrollmentId])
  @@index([stepId])
}

// ─── Notification Config ────────────────────────────────────────────────────

model NotificationConfig {
  id        String  @id @default(cuid())
  key       String  @unique   // e.g. "deal_won_emails", "deal_won_enabled"
  value     String  @db.Text  // JSON or plain text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ─── Contracts ──────────────────────────────────────────────────────────────

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURE
  SIGNED
  COMPLETED
  CANCELLED
}

model Contract {
  id     String         @id @default(cuid())
  status ContractStatus @default(DRAFT)

  // Link to deal
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id])

  // Client data (snapshot — copied from deal/contact/org at creation)
  razaoSocial        String
  nomeFantasia       String?
  cnpj               String
  endereco           String
  representante      String
  cpfRepresentante   String
  emailRepresentante String
  emailFinanceiro    String?

  // Product
  produto                  String // bgp-go-i, bgp-go-ii, bgp-go-iii, bgp-bi, bi-personalizado, bgp-strategy, bgp-valuation, brand-growth
  strategyModules          Json? // { crescimento: bool, redesenho: bool, recuperacao: bool }
  biOrigemDados            String?
  biQtdLicencas            String?
  biQtdTelasPersonalizadas String?

  // Financial
  valorMensal           Decimal  @db.Decimal(15, 2)
  diaVencimento         Int
  dataInicio            DateTime
  formaPagamento        String   @default("boleto")
  valorImplementacao    Decimal? @db.Decimal(15, 2)
  implementacaoParcelas Int?
  descontoMeses         Int?
  descontoPercentual    Decimal? @db.Decimal(5, 2)

  // Additional
  observacao String? @db.Text
  linkReadAi String?

  // Witnesses
  testemunha1Nome  String?
  testemunha1Cpf   String?
  testemunha1Email String?
  testemunha2Nome  String?
  testemunha2Cpf   String?
  testemunha2Email String?

  // Autentique
  autentiqueDocumentId String?
  autentiqueSentAt     DateTime?
  autentiqueSignedAt   DateTime?

  // Generated HTML (cached for re-viewing)
  htmlContent String? @db.Text

  signatures ContractSignatureRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
  @@index([status])
}

model ContractSignatureRecord {
  id          String    @id @default(cuid())
  contractId  String
  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  signerName  String
  signerEmail String
  signerRole  String // contratada, contratante, testemunha1, testemunha2
  status      String    @default("pending") // pending, signed
  signedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([contractId])
}

model ContractWitness {
  id    String @id @default(cuid())
  name  String
  cpf   String
  email String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

// ─── WhatsApp / Conversas ───────────────────────────────────────────────────

enum WhatsAppConnectionStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
}

enum WaCampaignStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

enum WaCampaignContactStatus {
  PENDING
  SENT
  ERROR
}

enum MessageSender {
  CLIENT
  BOT
  HUMAN
}

enum FollowUpTone {
  CASUAL
  REFORCO
  ENCERRAMENTO
}

model MeetingReminderStep {
  id            String  @id @default(cuid())
  minutesBefore Int // 240, 120, 60, 30, 15
  enabled       Boolean @default(true)
  message       String  @db.Text // template with {{nome}}, {{data}}, {{hora}}, {{falta}}

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([minutesBefore])
  @@index([minutesBefore])
}

model WhatsAppConfig {
  id                       String                   @id @default(cuid())
  zapiInstanceId           String                   @default("")
  zapiToken                String                   @default("")
  zapiClientToken          String                   @default("")
  baseUrl                  String                   @default("http://localhost:3001")
  companyName              String                   @default("")
  companyPhone             String                   @default("")
  meetingLink              String                   @default("")
  openaiApiKey             String                   @default("")
  botEnabled               Boolean                  @default(true)
  botSystemPrompt          String?                  @db.Text
  welcomeMessage           String?                  @db.Text
  connectionStatus         WhatsAppConnectionStatus @default(DISCONNECTED)
  followUpEnabled          Boolean                  @default(false)
  leadQualificationEnabled Boolean                  @default(true)
  sdrAutoMessageEnabled    Boolean                  @default(true)
  meetingReminderEnabled   Boolean                  @default(true)
  botPhoneNumber           String?

  followUpSteps WhatsAppFollowUpStep[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WhatsAppFollowUpStep {
  id           String       @id @default(cuid())
  order        Int
  delayMinutes Int          @default(30)
  tone         FollowUpTone @default(CASUAL)

  configId String
  config   WhatsAppConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([configId])
  @@index([configId, order])
}

model WhatsAppConversation {
  id                  String    @id @default(cuid())
  phone               String    @unique
  pushName            String?
  isActive            Boolean   @default(true)
  meetingBooked       Boolean   @default(false)
  needsHumanAttention Boolean   @default(false)
  status              String    @default("open") // open, closed
  lastMessageAt       DateTime?
  lastReadAt          DateTime?

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])

  assignedUserId String?
  assignedUser   User?    @relation("WhatsAppConversationAssignee", fields: [assignedUserId], references: [id])

  messages      WhatsAppMessage[]
  aiHistory     WhatsAppAIHistory[]
  followUpState WhatsAppFollowUpState?
  scheduledFollowUps ScheduledFollowUp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([contactId])
  @@index([assignedUserId])
  @@index([lastMessageAt])
  @@index([isActive])
  @@index([status])
}

model WhatsAppMessage {
  id           String        @id @default(cuid())
  sender       MessageSender
  text         String        @db.Text
  externalId   String?
  isFollowUp   Boolean       @default(false)
  followUpStep Int?
  metadata     Json?
  delivered    Boolean       @default(true)

  conversationId String
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderUserId String?
  senderUser   User?   @relation("WhatsAppMessageSender", fields: [senderUserId], references: [id])

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([externalId])
}

model WhatsAppAIHistory {
  id      String @id @default(cuid())
  role    String
  content String @db.Text

  conversationId String
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([conversationId, createdAt])
}

model WhatsAppFollowUpState {
  id                    String    @id @default(cuid())
  followUpCount         Int       @default(0)
  lastFollowUpAt        DateTime?
  lastBotMessageAt      DateTime?
  respondedSinceLastBot Boolean   @default(false)
  paused                Boolean   @default(false)

  conversationId String               @unique
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId])
}

model ScheduledFollowUp {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  stepNumber      Int      // 1, 2, 3...
  tone            String   // CASUAL, REFORCO, ENCERRAMENTO
  delayMinutes    Int
  scheduledAt     DateTime // When this follow-up will fire
  status          String   @default("PENDING") // PENDING, SENT, CANCELLED
  sentAt          DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime @default(now())

  @@index([conversationId])
  @@index([conversationId, status])
  @@index([scheduledAt])
}

model WhatsAppCampaign {
  id          String           @id @default(cuid())
  name        String
  message     String           @db.Text
  status      WaCampaignStatus @default(DRAFT)
  startedAt   DateTime?
  completedAt DateTime?

  stageId String?
  stage   PipelineStage? @relation(fields: [stageId], references: [id])

  segmentId String?
  segment   Segment? @relation(fields: [segmentId], references: [id])

  contacts WhatsAppCampaignContact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([stageId])
  @@index([segmentId])
}

// ─── WhatsApp Message Templates ─────────────────────────────────────────────

model WhatsAppMessageTemplate {
  id       String @id @default(cuid())
  name     String @unique // shortcut name like "boas-vindas", "reuniao"
  category String @default("geral") // categorization
  content  String @db.Text // the message text with placeholders like {{nome}}, {{empresa}}

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([category])
}

// ─── Calendly Integration ──────────────────────────────────────────────────

model CalendlyConfig {
  id              String  @id @default(cuid())
  apiKey          String  @default("")
  webhookSecret   String  @default("")
  isActive        Boolean @default(true)
  organizationUri String  @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CalendlyEvent {
  id              String   @id @default(cuid())
  calendlyEventId String   @unique
  eventType       String
  inviteeEmail    String
  inviteeName     String?
  hostEmail       String?
  hostName        String?
  startTime       DateTime
  endTime         DateTime
  status          String   @default("active")

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id])
  dealId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([inviteeEmail])
  @@index([calendlyEventId])
  @@index([contactId])
}

model WhatsAppCampaignContact {
  id     String                  @id @default(cuid())
  phone  String
  status WaCampaignContactStatus @default(PENDING)
  sentAt DateTime?
  error  String?

  campaignId String
  campaign   WhatsAppCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([campaignId])
  @@index([campaignId, status])
}
