# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/bgpgo_crm?schema=public"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_KEY="your-service-key"

# Server
PORT=3001
CORS_ORIGIN="http://localhost:3000"
API_URL="http://localhost:3001/api"
NODE_ENV=development

# Produção:
# CORS_ORIGIN="https://crm.bertuzzipatrimonial.com.br"
# API_URL="https://api-crm.bertuzzipatrimonial.com.br/api"

# Email (Resend)
RESEND_API_KEY=re_your_key_here

# OpenAI (para bot WhatsApp e geração de copy)
OPENAI_API_KEY=sk-your-key-here

# WhatsApp Evolution API (para módulo Conversas)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
